{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability granted to both the main and glass windows.",
  "windows": ["main", "glass"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "log:default",
    "store:default",
    "shell:default",
    "liquid-glass:default"
  ]
}
